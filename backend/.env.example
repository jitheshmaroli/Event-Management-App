PORT=5000
NODE_ENV=development

MONGO_URI=mongodb://localhost:27017/event-booking

JWT_ACCESS_SECRET=your-very-long-random-access-secret
JWT_REFRESH_SECRET=your-very-long-random-refresh-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=30d

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="Event Booking <noreply@yourdomain.com>"